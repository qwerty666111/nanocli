# Arc Testnet RPC endpoint. Use one of the official endpoints:
#   https://arc-testnet.drpc.org
#   https://rpc.testnet.arc.network
ARC_TESTNET_RPC_URL=https://arc-testnet.drpc.org

# Deployer wallet private key (with 0x prefix). Never share or commit.
PRIVATE_KEY=0x...

# Deployed contract addresses (filled after deployment)
BATCH_PAYMENT_CONTRACT_ADDRESS=0x...
NANO_USDC_ADDRESS=0x...

# Python CLI wallet config (used by send-batch and agent)
NANOCLI_PRIVATE_KEY=0x...
NANOCLI_VAULT_KEY=0x...

# Frontend wallet connect (optional, for WalletConnect)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Arc Testnet chain id
NEXT_PUBLIC_CHAIN_ID=5042002
